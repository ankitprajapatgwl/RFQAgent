# ---------------------------------------------------------------------------
# RFQ Agent — environment configuration
# Copy this file to `.env` and adjust values. NEVER commit a real `.env`.
# ---------------------------------------------------------------------------

# Application
APP_NAME="RFQ Agent — Auth Service"
ENVIRONMENT=development          # development | production
DEBUG=true

# ASGI server
HOST=0.0.0.0
PORT=8000

# Database (SQLAlchemy URL)
#   Manual/local default (SQLite, zero setup):
DATABASE_URL=sqlite:///./data/rfq_agent.db
#   Docker Compose (PostgreSQL) — set automatically in docker-compose.yml:
# DATABASE_URL=postgresql+psycopg2://rfq:rfq@db:5432/rfq

# JWT — MUST be overridden with a long random value in production.
#   Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# HTML session cookie
SESSION_COOKIE_NAME=rfq_access_token

# Logging
LOG_LEVEL=INFO

# Anthropic — used to generate sample email-drafting queries on the dashboard.
ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_MODEL=claude-haiku-4-5-20251001
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Email delivery (outbound send + inbound reply tracking).
#
# Only EngageLab is wired up today. The app boots fine without any of these
# set — the provider is built lazily and raises a clear error the first time a
# send/inbound is actually attempted with a required value missing.
# ---------------------------------------------------------------------------

# Provider whose inbound-webhook payload POST /webhooks/inbound parses, and the
# default provider used for outbound sends.
INBOUND_EMAIL_PROVIDER=engagelab
# Inbound replies scoring above this SpamAssassin-style threshold are discarded.
EMAIL_SPAM_THRESHOLD=5.0

# EngageLab credentials (Send Settings → API_USER, created as "Trigger Email").
# ENGAGELAB_API_USER is the dashboard-created API_USER string, NOT your login email.
ENGAGELAB_API_USER=
ENGAGELAB_API_KEY=
# Region base URL — Singapore default; Turkey: https://emailapi-tr.engagelab.com
ENGAGELAB_API_BASE=https://email.api.engagelab.cc
# Verified sending subdomain; also EngageLab's inbound MX target. Required to
# send or to match inbound replies. Each user's permanent sending_email is
# assigned on this domain at registration.
ENGAGELAB_OUTBOUND_DOMAIN=
# From-header display name / signature.
ENGAGELAB_COMPANY_NAME=Your Company

# ---------------------------------------------------------------------------
# PostgreSQL credentials used by the `db` service in docker-compose.yml.
# ---------------------------------------------------------------------------
POSTGRES_USER=rfq
POSTGRES_PASSWORD=rfq
POSTGRES_DB=rfq
